<%- include('partials/header', { title: 'Deploying — Setup Portal', active: 'deploy' }) %>

<header class="page-header">
    <div>
        <h1 id="page-title">Deploying your site… <span class="emoji-accent" id="page-emoji">⏳</span></h1>
        <p class="page-subtitle"><%= deployment.domain %> · started <%= new Date(deployment.startedAt).toLocaleTimeString() %></p>
    </div>
</header>

<!-- In progress card -->
<div class="card status-card" id="status-card">
    <div class="status-head">
        <div class="status-spinner"></div>
        <div>
            <strong id="current-step">Starting deployment…</strong>
            <p class="muted small">This usually takes 60-120 seconds</p>
        </div>
    </div>

    <div class="progress-rail">
        <div class="progress-fill" id="progress-fill"></div>
    </div>

    <div class="steps-list" id="steps-list"></div>
</div>

<!-- Success card -->
<div class="card success-card" id="success-card" style="display:none;">
    <div class="success-icon">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
    </div>
    <h2>Site deployed!</h2>
    <p class="muted">Your new WordPress site is ready.</p>

    <div class="result-grid" id="result-grid"></div>

    <p class="hint hint-warn">⏱ The site might take another 30-60 seconds to fully install plugins. If you see errors, wait and refresh.</p>

    <div class="form-actions">
        <a href="/deploy" class="btn btn-secondary">Deploy another</a>
        <a id="open-admin" href="#" target="_blank" class="btn btn-primary">
            Open admin
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                <polyline points="15 3 21 3 21 9"></polyline>
                <line x1="10" y1="14" x2="21" y2="3"></line>
            </svg>
        </a>
    </div>
</div>

<!-- Error card -->
<div class="card error-card" id="error-card" style="display:none;">
    <div class="error-icon">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"></circle>
            <line x1="15" y1="9" x2="9" y2="15"></line>
            <line x1="9" y1="9" x2="15" y2="15"></line>
        </svg>
    </div>
    <h2>Deployment failed</h2>
    <p id="error-message" class="muted"></p>
    <div class="form-actions">
        <a href="/deploy" class="btn btn-primary">Try again</a>
    </div>
</div>

<script>
(function() {
    var deployId = '<%= deployment.id %>';
    var stepsList = document.getElementById('steps-list');
    var currentStep = document.getElementById('current-step');
    var statusCard = document.getElementById('status-card');
    var successCard = document.getElementById('success-card');
    var errorCard = document.getElementById('error-card');
    var resultGrid = document.getElementById('result-grid');
    var errorMessage = document.getElementById('error-message');
    var progressFill = document.getElementById('progress-fill');
    var pageTitle = document.getElementById('page-title');
    var pageEmoji = document.getElementById('page-emoji');
    var renderedSteps = {};

    // Approximate progress mapping (which step = what %)
    var stepProgress = {
        start: 5,
        create: 10,
        create_done: 20,
        envs: 25,
        envs_done: 40,
        deploy: 50,
        deploy_done: 60,
        fqdn: 70,
        fqdn_done: 80,
        fqdn_warn: 80,
        restart: 85,
        restart_done: 90,
        restart_warn: 90,
        done: 100
    };

    function escapeHtml(s) {
        return String(s == null ? '' : s)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');
    }

    function poll() {
        fetch('/deploy/' + deployId + '/status')
            .then(function(r) { return r.json(); })
            .then(function(data) {
                data.steps.forEach(function(s, i) {
                    var key = i + '-' + s.step;
                    if (!renderedSteps[key]) {
                        renderedSteps[key] = true;
                        var div = document.createElement('div');
                        var iconClass = s.step.indexOf('warn') !== -1 ? 'warn' : 'done';
                        div.className = 'step-item step-' + iconClass;
                        div.innerHTML =
                            '<span class="step-icon">' +
                                (iconClass === 'warn'
                                    ? '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path></svg>'
                                    : '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>') +
                            '</span>' +
                            '<span class="step-msg">' + escapeHtml(s.message) + '</span>';
                        stepsList.appendChild(div);
                    }
                });

                // Update progress
                var lastStep = data.steps.length > 0 ? data.steps[data.steps.length - 1].step : 'start';
                var pct = stepProgress[lastStep] || 5;
                progressFill.style.width = pct + '%';

                if (data.status === 'done') {
                    statusCard.style.display = 'none';
                    successCard.style.display = 'block';
                    pageTitle.firstChild.textContent = 'Site deployed! ';
                    pageEmoji.textContent = '🎉';

                    var r = data.result;
                    document.getElementById('open-admin').href = r.adminUrl;

                    resultGrid.innerHTML =
                        '<div class="result-row">' +
                            '<span class="result-label">Site URL</span>' +
                            '<a class="result-value" href="' + escapeHtml(r.siteUrl) + '" target="_blank">' + escapeHtml(r.siteUrl) + '</a>' +
                        '</div>' +
                        '<div class="result-row">' +
                            '<span class="result-label">Admin URL</span>' +
                            '<a class="result-value" href="' + escapeHtml(r.adminUrl) + '" target="_blank">' + escapeHtml(r.adminUrl) + '</a>' +
                        '</div>' +
                        '<div class="result-row">' +
                            '<span class="result-label">Username</span>' +
                            '<code class="result-value">' + escapeHtml(r.adminUser) + '</code>' +
                        '</div>' +
                        '<div class="result-row">' +
                            '<span class="result-label">Password</span>' +
                            '<code class="result-value password-value">' +
                                '<span id="pass-text">' + escapeHtml(r.adminPass) + '</span>' +
                                '<button type="button" class="copy-btn" onclick="copyPass(this)">' +
                                    '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>' +
                                '</button>' +
                            '</code>' +
                        '</div>';
                    return;
                }

                if (data.status === 'failed') {
                    statusCard.style.display = 'none';
                    errorCard.style.display = 'block';
                    pageTitle.firstChild.textContent = 'Deployment failed ';
                    pageEmoji.textContent = '⚠️';
                    errorMessage.textContent = data.error || 'Unknown error';
                    return;
                }

                if (data.steps.length > 0) {
                    currentStep.textContent = data.steps[data.steps.length - 1].message;
                }

                setTimeout(poll, 1500);
            })
            .catch(function(err) {
                console.error('Polling error:', err);
                setTimeout(poll, 3000);
            });
    }

    poll();
})();

function copyPass(btn) {
    var text = document.getElementById('pass-text').textContent;
    navigator.clipboard.writeText(text).then(function() {
        btn.classList.add('copied');
        setTimeout(function() { btn.classList.remove('copied'); }, 1500);
    });
}
</script>

<%- include('partials/footer') %>
