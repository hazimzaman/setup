<%- include('partials/header', { title: 'Deploy New Site — Setup Portal', active: 'deploy' }) %>

<header class="page-header">
    <div>
        <h1>Deploy new site <span class="emoji-accent">🚀</span></h1>
        <p class="page-subtitle">Configure and launch a fresh WordPress site in about 90 seconds</p>
    </div>
</header>

<% if (error) { %>
    <div class="alert alert-error"><%= error %></div>
<% } %>

<form method="POST" action="/deploy" class="deploy-form">
    <!-- Site basics -->
    <section class="card form-section">
        <div class="section-head">
            <span class="section-icon section-icon-orange">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"></circle>
                    <line x1="2" y1="12" x2="22" y2="12"></line>
                    <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
                </svg>
            </span>
            <div>
                <h3>Site basics</h3>
                <p>Subdomain and site title</p>
            </div>
        </div>

        <div class="grid-two">
            <div class="field">
                <label for="subdomain">Subdomain</label>
                <div class="input-group">
                    <input type="text" id="subdomain" name="subdomain"
                           value="<%= formData && formData.subdomain || '' %>"
                           required pattern="[a-z0-9][a-z0-9-]*[a-z0-9]"
                           placeholder="client1"
                           title="lowercase letters, numbers, and hyphens">
                    <span class="input-suffix">.<%= baseDomain %></span>
                </div>
                <p class="field-hint">Used as the site's URL. Lowercase letters, numbers, and hyphens.</p>
            </div>

            <div class="field">
                <label for="siteTitle">Site title</label>
                <input type="text" id="siteTitle" name="siteTitle"
                       value="<%= formData && formData.siteTitle || '' %>"
                       required placeholder="Client 1 Website">
                <p class="field-hint">Appears in the WP admin and front-end.</p>
            </div>
        </div>
    </section>

    <!-- Admin credentials -->
    <section class="card form-section">
        <div class="section-head">
            <span class="section-icon section-icon-green">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                    <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                </svg>
            </span>
            <div>
                <h3>Admin credentials</h3>
                <p>How you'll log into wp-admin</p>
            </div>
        </div>

        <div class="grid-two">
            <div class="field">
                <label for="adminUser">Admin username</label>
                <input type="text" id="adminUser" name="adminUser"
                       value="<%= formData && formData.adminUser || '' %>"
                       required minlength="3" placeholder="admin">
            </div>

            <div class="field">
                <label for="adminEmail">Admin email</label>
                <input type="email" id="adminEmail" name="adminEmail"
                       value="<%= formData && formData.adminEmail || '' %>"
                       required placeholder="admin@example.com">
            </div>
        </div>

        <div class="field">
            <label for="adminPass">Admin password</label>
            <div class="input-group">
                <input type="text" id="adminPass" name="adminPass" required minlength="12"
                       placeholder="At least 12 chars, mix case + numbers + symbols">
                <button type="button" class="input-action" onclick="generatePassword()" title="Generate strong password">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="23 4 23 10 17 10"></polyline>
                        <polyline points="1 20 1 14 7 14"></polyline>
                        <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"></path>
                    </svg>
                </button>
            </div>
            <p class="field-hint">Use a strong password — Wordfence will reject weak or breached ones.</p>
        </div>
    </section>

    <!-- Theme -->
    <section class="card form-section">
        <div class="section-head">
            <span class="section-icon section-icon-purple">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="13.5" cy="6.5" r=".5"></circle>
                    <circle cx="17.5" cy="10.5" r=".5"></circle>
                    <circle cx="8.5" cy="7.5" r=".5"></circle>
                    <circle cx="6.5" cy="12.5" r=".5"></circle>
                    <path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z"></path>
                </svg>
            </span>
            <div>
                <h3>Theme</h3>
                <p>Choose the default theme</p>
            </div>
        </div>

        <div class="theme-grid">
            <label class="theme-option">
                <input type="radio" name="theme" value="bricks" <%= (!formData || !formData.theme || formData.theme === 'bricks') ? 'checked' : '' %>>
                <div class="theme-card">
                    <div class="theme-preview theme-preview-bricks">
                        <div class="bar"></div><div class="bar bar-2"></div><div class="bar bar-3"></div>
                    </div>
                    <h4>Bricks</h4>
                    <p>Visual builder for custom layouts</p>
                </div>
            </label>

            <label class="theme-option">
                <input type="radio" name="theme" value="etch-theme" <%= (formData && formData.theme === 'etch-theme') ? 'checked' : '' %>>
                <div class="theme-card">
                    <div class="theme-preview theme-preview-etch">
                        <div class="bar"></div><div class="bar bar-2"></div><div class="bar bar-3"></div>
                    </div>
                    <h4>Etch</h4>
                    <p>Minimal block theme</p>
                </div>
            </label>
        </div>
    </section>

    <!-- Plugins -->
    <section class="card form-section">
        <div class="section-head">
            <span class="section-icon section-icon-blue">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                    <polyline points="22 4 12 14.01 9 11.01"></polyline>
                </svg>
            </span>
            <div>
                <h3>Activate plugins</h3>
                <p>All plugins are pre-installed. Check what to activate by default.</p>
            </div>
        </div>

        <% 
        const allPlugins = [
            { slug: 'admin-site-enhancements', label: 'Admin Site Enhancements', defaultOn: true },
            { slug: 'advanced-custom-fields-pro', label: 'ACF Pro', defaultOn: true },
            { slug: 'automaticcss-plugin', label: 'Automatic.css' },
            { slug: 'bricks-advanced-themer', label: 'Bricks Advanced Themer' },
            { slug: 'bricksextras', label: 'BricksExtras' },
            { slug: 'bricksforge', label: 'Bricksforge' },
            { slug: 'etch', label: 'Etch' },
            { slug: 'fluentformpro', label: 'Fluent Forms Pro' },
            { slug: 'fluent-smtp', label: 'Fluent SMTP', defaultOn: true },
            { slug: 'happyfiles-pro', label: 'HappyFiles Pro' },
            { slug: 'motionpage', label: 'Motion Page' },
            { slug: 'wordfence', label: 'Wordfence', defaultOn: true },
            { slug: 'wpcodebox2', label: 'WPCodeBox 2' },
            { slug: 'wp-grid-builder', label: 'WP Grid Builder' },
            { slug: 'wp-grid-builder-bricks', label: 'WP Grid Builder Bricks' },
            { slug: 'ws-form-pro', label: 'WS Form Pro' }
        ];
        const submittedPlugins = (formData && formData.plugins && formData.plugins.length > 0) ? formData.plugins : null;
        %>

        <div class="plugins-grid">
            <% allPlugins.forEach(p => { 
                const isChecked = submittedPlugins
                    ? submittedPlugins.includes(p.slug)
                    : !!p.defaultOn;
            %>
                <label class="plugin-chip">
                    <input type="checkbox" name="plugins" value="<%= p.slug %>" <%= isChecked ? 'checked' : '' %>>
                    <span class="plugin-check"></span>
                    <span class="plugin-name"><%= p.label %></span>
                </label>
            <% }) %>
        </div>
    </section>

    <!-- DNS warning -->
    <div class="alert alert-warning">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0; margin-top:2px;">
            <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
            <line x1="12" y1="9" x2="12" y2="13"></line>
            <line x1="12" y1="17" x2="12.01" y2="17"></line>
        </svg>
        <div>
            <strong>Before deploying:</strong> Make sure DNS A record exists pointing your subdomain to the server, with Cloudflare proxy <strong>OFF</strong> (gray cloud). Otherwise SSL will fail.
        </div>
    </div>

    <div class="form-actions">
        <a href="/" class="btn btn-secondary">Cancel</a>
        <button type="submit" class="btn btn-primary">
            Deploy Site
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
        </button>
    </div>
</form>

<script>
function generatePassword() {
    const length = 20;
    const charset = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789!@#$%^&*';
    let pass = '';
    const arr = new Uint32Array(length);
    crypto.getRandomValues(arr);
    for (let i = 0; i < length; i++) {
        pass += charset[arr[i] % charset.length];
    }
    document.getElementById('adminPass').value = pass;
}
</script>

<%- include('partials/footer') %>
